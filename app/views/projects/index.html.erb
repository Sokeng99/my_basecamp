<div class="container mt-4" style="border: 1px solid #ccc; padding: 20px; border-radius: 5px;">
  <h1>Projects</h1>

  <!-- Navigation Tabs -->
  <ul class="nav nav-tabs" role="tablist" id="projectTabs">
    <% tabs = { "All Projects" => "all-projects", "Created By Me" => "created-by-me", "Shared With Me" => "shared-with-me" } %>
    <% tabs.each_with_index do |(label, id), index| %>
      <li class="nav-item" role="presentation">
        <button
          class="nav-link <%= 'active' if index.zero? %>"
          id="<%= "#{id}-tab" %>"
          data-bs-toggle="tab"
          data-bs-target="#<%= id %>"
          type="button"
          role="tab"
          aria-controls="<%= id %>"
          aria-selected="<%= index.zero? %>"
          style="color: blueviolet;">
          <%= label %>
        </button>
      </li>
    <% end %>
  </ul>

  <!-- Tab Content -->
  <div class="tab-content mt-3" id="projectTabsContent">
    <% { "all-projects" => @all_projects, "created-by-me" => @created_projects, "shared-with-me" => @shared_projects }.each do |id, projects| %>
      <div class="tab-pane fade <%= 'show active' if id == 'all-projects' %>" id="<%= id %>" role="tabpanel" aria-labelledby="<%= "#{id}-tab" %>">
        <% if projects.present? %>
          <div class="row d-flex justify-content-start flex-wrap">
            <% projects.each do |project| %>
              <div class="col-lg-3 col-md-6 col-sm-12 mb-4 d-flex align-items-stretch">
                <div class="card w-100 border rounded shadow" id="category-card">
                  <div class="card-body">
                    <h3 class="card-title"><%= project.title %></h3>
                    <p class="card-title">Description: <%= project.description %></p>
                    <p class="card-title mb-3">Created by: <%= project.creator.email %></p>

                    <div class="d-flex flex-row mb-3">
                      <div class="me-4">
                        <i class="fa-solid fa-user-group"></i>
                        <span><%= project.members.count + 1 %></span>
                      </div>
                      <div>
                        <i class="fa-solid fa-comments"></i>
                      </div>
                    </div>

                    <div class="d-flex flex-row justify-content-between">
                      <div><%= link_to "Show", project_path(project), class: 'btn btn-outline-primary text-black' %></div>
                      <div><%= link_to "Edit", edit_project_path(project), class: 'btn btn-outline-info text-black' %></div>
                      <div><%= button_to "Delete", project_path(project), method: :delete, class: 'btn btn-outline-danger text-black' %></div>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p>No <%= id.tr("-", " ") %> available.</p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
