<style>
    .btn-custom {
      display: inline-block;
      background: blueviolet;
      color: white;
      padding: 10px 15px;
      text-decoration: none black;
      border-radius: 5px;
      margin-top: 10px;
      cursor: pointer;
      border: none;
      color: black;
    }
    .btn-custom:hover {
      background: #DA0463;
    }
</style>

<h1>Add Project</h1>
<%= form_with model: @project, local: true do |form| %>
  <div class="mb-3">
    <%= form.label :title, "Project Title", class: "form-label" %>
    <%= form.text_field :title, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :description, "Project Description", class: "form-label" %>
    <%= form.text_area :description, class: "form-control", rows: 5 %>
  </div>

  <%= form.submit "Create Project", class: "btn-custom" %>
<% end %>
